{
  "name": "@florentine-ai/api",
  "version": "1.0.0",
  "homepage": "https://florentine.ai",
  "description": "Node.js API Wrapper for Florentine.ai – query MongoDB & MySQL databases in natural language",
  "type": "module",
  "keywords": [
    "mongodb",
    "aggregation",
    "mysql",
    "query",
    "natural-language",
    "ai",
    "llm",
    "database",
    "api",
    "florentine"
  ],
  "author": "Jens Lübberstedt <jens@florentine.ai>",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/florentine-ai/api.git"
  },
  "bugs": {
    "url": "https://github.com/florentine-ai/api/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:integration": "dotenv -e .env.test -- vitest run tests/ask.integration.test.ts"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bson": "^7.2.0",
    "zod": "^4.3.6"
  }
}
